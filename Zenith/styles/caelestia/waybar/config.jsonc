    },

    "custom/desktop-logo": {
        "format": "ًں–³",
        "tooltip": false
    },

    "custom/desktop": {
        "format": "Desktop",
        "rotate": 270
    },

    "custom/keybinds": {
        "format": "ï„œ",
        "on-click": "sh -c ~/.config/Zenith/scripts/rofi_menu/keybindings.sh",
        "tooltip": false

    },

    "custom/celender": {
        "format": "ï„œ",
        "on-click": "sh -c ~/.config/Zenith/scripts/rofi_menu/keybindings.sh",
        "tooltip-format": "<tt>{calendar}</tt>"
    },

    "clock": {
        // Matches the vertical stack in your image: 05\n11 â€” 17\n09
        "format": "{:%H\n%M}", 
        "tooltip-format": "{:%a, %h %d, %Y}"
    },

    "custom/logo": {
        "format": "ïŒƒ",
        "on-click": "~/.config/Zenith/scripts/rofi_menu/walker/walker.sh",
        "tooltip-format": "Arch linux BTW"
    },

    // 2. Define the group container
    "group/tools": {
        "orientation": "vertical", // Stacks them vertically
        "modules": [
            "group/tray-expander",
            "pulseaudio",
            "battery"
        ]
    },


    "pulseaudio": {
        "format": "{icon}",
        "format-icons": {
            "default": ["ï€¦", "ï€§", "ï€¨"]
        },
        "on-click": "kitty --class floating-terminal -e wiremix --tab output"
    },


   "network": {
        "interval": 3,
        "format-wifi": "{icon}",
        "format-ethernet": "َ°ˆ€ LAN",
        "format-disconnected": "َ°¤®  No Net",
        "format-icons": [
          "َ°¤¯", // 0%
          "َ°¤ں", // 25%
          "َ°¤¢", // 50%
          "َ°¤¥", // 75%
          "َ°¤¨"  // 100%
        ],
        "tooltip-format-wifi": "َ°¤¨  {essid} ({frequency} GHz)\nâ‡£{bandwidthDownBytes} â‡،{bandwidthUpBytes}",
        "tooltip-format-ethernet": "َ°ˆ€  {ifname}\nâ‡£{bandwidthDownBytes} â‡،{bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "kitty --class floating-terminal -e impala" 
    },
    

    "battery": {
        "format": "{icon}",
        "format-icons": ["ï‰„", "ï‰ƒ", "ï‰‚", "ï‰پ", "ï‰€"],
        "on-click": "bash ~/.config/rofi/scripts/power-profile.sh",
        "tooltip-format-discharging": "{power:>1.0f}Wâ†“ {capacity}%",
        "tooltip-format-charging": "{power:>1.0f}Wâ†‘ {capacity}%"
    },

    "custom/power": {
        "format": "ï€‘ ",
        "on-click": "~/.config/Zenith/scripts/rofi_menu/powermenu.sh",
        "tooltip": false
    },

    "group/tray-expander": {
        "orientation": "inherit",
        "drawer": {
          "transition-duration": 600,
          "children-class": "tray-group-item"
        },
        "modules": ["custom/expand-icon", "tray"]
    },

    "custom/expand-icon": {
        "format": "â–²",
        "tooltip": false,
        "on-scroll-up": "",
        "on-scroll-down": "",
        "on-scroll-left": "",
        "on-scroll-right": ""
    },

    "tray": {
      "icon-size": 16,
      "spacing": 10,
      "show-passive-items": true // This forces items to show even if they aren't "active"
    }

}
